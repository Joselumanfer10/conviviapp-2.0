# ============================================
# ConviviApp 2.0 - Variables de Entorno
# ============================================
# Copia este archivo como .env y ajusta los valores

# --- Base de Datos ---
DB_USER=conviviapp
DB_PASSWORD=CHANGE_ME
DB_NAME=conviviapp
DATABASE_URL=postgresql://conviviapp:CHANGE_ME@localhost:5432/conviviapp?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT (CAMBIAR EN PRODUCCION) ---
JWT_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Server ---
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Client (Vite) ---
VITE_API_URL=http://localhost:3000/api
